# ==============================================================
# InternLink — Environment Variables
# Copy this file to .env and fill in the values
# ==============================================================

# Flask
FLASK_SECRET_KEY=
FLASK_ENV=development
FLASK_DEBUG=1

# Database (Supabase PostgreSQL)
DATABASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_STORAGE_BUCKET=internlink

# AI (Gemini API)
GEMINI_API_KEY=

# Mail (for Forgot Password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
